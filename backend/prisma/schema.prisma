generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  guest
  user
  admin

  @@map("user_role")
}

model User {
  id           String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  // New registrations start as `guest` and cannot use the app until an admin promotes
  // them to `user` (or `admin`) via the backoffice — see GuestBlockGuard.
  role         UserRole @default(guest)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  chatSessions  ChatSession[]
  providerCredentials ProviderCredential[]
  adminPermissionGrants AdminPermissionGrant[]
  adminAuditLogEntriesAsActor  AdminAuditLogEntry[] @relation("AdminAuditActor")
  adminAuditLogEntriesAsTarget AdminAuditLogEntry[] @relation("AdminAuditTarget")

  @@map("users")
}

enum AdminPermission {
  users_view
  users_manage_status
  users_manage_role
  users_manage_permissions
  dashboard_view
  audit_log_view

  @@map("admin_permission")
}

model AdminPermissionGrant {
  id         String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  permission AdminPermission
  grantedAt  DateTime        @default(now()) @map("granted_at")
  grantedBy  String?         @map("granted_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("admin_permission_grants")
}

enum AdminAuditAction {
  user_role_changed
  user_status_changed
  user_permissions_changed

  @@map("admin_audit_action")
}

model AdminAuditLogEntry {
  id           String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  actorUserId  String?          @map("actor_user_id") @db.Uuid
  targetUserId String?          @map("target_user_id") @db.Uuid
  action       AdminAuditAction
  detail       Json
  createdAt    DateTime         @default(now()) @map("created_at")

  actor  User? @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@map("admin_audit_log_entries")
}

enum AiProvider {
  ollama
  claude
  openai

  @@map("ai_provider")
}

enum MessageRole {
  user
  assistant
  system

  @@map("message_role")
}

enum StreamStatus {
  pending
  streaming
  complete
  error
  stopped

  @@map("stream_status")
}

model ChatSession {
  id              String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  title           String     @default("New Chat")
  defaultProvider AiProvider @default(ollama) @map("default_provider")
  defaultModel    String     @map("default_model")
  isArchived      Boolean    @default(false) @map("is_archived")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  artifacts CodeArtifact[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("chat_sessions")
}

model Message {
  id              String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  sessionId       String       @map("session_id") @db.Uuid
  role            MessageRole
  content         String
  provider        AiProvider?
  model           String?
  streamingStatus StreamStatus @default(complete) @map("streaming_status")
  errorMessage    String?      @map("error_message")
  tokenCount      Int?         @map("token_count")
  createdAt       DateTime     @default(now()) @map("created_at")

  session   ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  artifacts CodeArtifact[]

  @@index([sessionId, createdAt])
  @@map("messages")
}

enum ArtifactOrigin {
  ai
  user

  @@map("artifact_origin")
}

model CodeArtifact {
  id               String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  messageId        String         @map("message_id") @db.Uuid
  sessionId        String         @map("session_id") @db.Uuid
  filename         String
  language         String
  content          String
  revision         Int            @default(1)
  parentArtifactId String?        @map("parent_artifact_id") @db.Uuid
  origin           ArtifactOrigin
  createdAt        DateTime       @default(now()) @map("created_at")

  message        Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  session        ChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parentArtifact CodeArtifact?  @relation("ArtifactRevision", fields: [parentArtifactId], references: [id])
  childRevisions CodeArtifact[] @relation("ArtifactRevision")

  @@unique([sessionId, filename, revision])
  @@index([sessionId, filename, revision(sort: Desc)])
  @@index([messageId])
  @@map("code_artifacts")
}

model RefreshToken {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @map("token_hash")
  familyId      String    @map("family_id") @db.Uuid
  issuedAt      DateTime  @default(now()) @map("issued_at")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  replacedById  String?   @unique @map("replaced_by_id") @db.Uuid
  userAgent     String?   @map("user_agent")
  ipAddress     String?   @map("ip_address") @db.Inet

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy  RefreshToken? @relation("TokenRotation", fields: [replacedById], references: [id])
  replaces    RefreshToken? @relation("TokenRotation")

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@map("refresh_tokens")
}

model ProviderCredential {
  id                String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId            String     @map("user_id") @db.Uuid
  provider          AiProvider
  encryptedApiKey   Bytes      @map("encrypted_api_key")
  encryptionVersion Int        @default(1) @map("encryption_version")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider])
  @@map("provider_credentials")
}
