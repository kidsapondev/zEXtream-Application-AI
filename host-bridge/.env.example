# host-bridge runs directly on the deployment host (not in Docker) — see
# docs/deployment.md for the full runbook. Copy this to .env in this directory (or set
# these however you normally run a background process on the host) and fill in real
# paths/secret.

PORT=4171

# Must match HOST_BRIDGE_TOKEN in the backend's .env exactly — generate with e.g.
# `openssl rand -base64 32`. Anything that can reach this port and knows this token can
# spawn claude/codex under your login, so treat it like any other secret.
HOST_BRIDGE_TOKEN=changeme_generate_a_long_random_secret

# Absolute paths to the claude/codex CLI executables on this machine. Find yours with:
#   Windows: Get-ChildItem -Path $env:APPDATA,$env:LOCALAPPDATA -Filter claude.exe -Recurse
#            Get-ChildItem -Path $env:LOCALAPPDATA -Filter codex.exe -Recurse
CLAUDE_EXE_PATH=C:\path\to\claude.exe
CODEX_EXE_PATH=C:\path\to\codex.exe

# Optional: working directory for every spawned claude/codex invocation. Must stay
# outside any git repo and free of any CLAUDE.md/AGENTS.md — defaults to the OS temp
# directory, which already satisfies that.
# BRIDGE_NEUTRAL_CWD=C:\path\to\an\empty\scratch\directory

# Optional: wall-clock cap per chat invocation, in milliseconds.
# BRIDGE_CHAT_TIMEOUT_MS=120000
