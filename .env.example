# Postgres
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_DB=chatapp
DATABASE_URL=postgresql://chatapp:changeme_dev_password@postgres:5432/chatapp

# JWT
JWT_ACCESS_SECRET=changeme_generate_a_long_random_secret
JWT_REFRESH_SECRET=changeme_generate_a_different_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for storing user-supplied Claude/OpenAI API keys (32 bytes, base64)
API_KEY_ENCRYPTION_KEY=changeme_32_byte_base64_key

# AI backends
OLLAMA_BASE_URL=http://host.docker.internal:11434

# CORS allowlist (dev only; prod serves frontend+backend same-origin via nginx, so leave
# this empty/unset in prod — CORS gets disabled outright rather than defaulting to allow
# all origins). Comma-separated list of exact origins, e.g.:
#   CORS_ORIGIN=http://localhost:4200,https://staging.example.com
CORS_ORIGIN=http://localhost:4200

NODE_ENV=development

# Number of trusted reverse-proxy hops in front of the backend (nginx = 1); leave 0 for
# direct/local runs without a proxy in front, since trusting proxy headers you don't
# control lets clients spoof their IP. The dev override forces this to 0 regardless.
TRUST_PROXY=1

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Optional: error reporting (Sentry). Leave unset to disable entirely — nothing is sent
# anywhere unless a DSN is configured. See docs/deployment.md for setup.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production

# Optional: only needed with docker-compose.cloudflare.yml, which exposes the stack on a
# public domain via a Cloudflare Tunnel (no open router ports / public IP required — fits
# a home server). Token comes from the Cloudflare Zero Trust dashboard: Networks >
# Tunnels > (your tunnel) > Configure. See docker-compose.cloudflare.yml for full setup.
# CLOUDFLARE_TUNNEL_TOKEN=

# Secrets (DATABASE_URL, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET,
# API_KEY_ENCRYPTION_KEY) can each be supplied as a file instead of a plain value by
# setting the corresponding "<KEY>_FILE" variable to a file path (its content is read
# and trimmed at startup; a _FILE value always wins over a plain value of the same key).
# This is how docker-compose.secrets.yml wires in Docker Compose secrets, and the same
# convention works with a Vault agent template, a Kubernetes Secret mounted as a file, or
# any other secret manager that can render a value to disk — e.g.:
#   JWT_ACCESS_SECRET_FILE=/run/secrets/jwt_access_secret
